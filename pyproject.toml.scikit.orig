[build-system]
requires = [
    "scikit-build-core>=0.4.3",
    "cmake>=3.26.1",
    "setuptools>=42",
    "wheel",
    "ninja"
]
build-backend = "scikit_build_core.build"

[project]
name = "flashinfer"
dynamic = ["version"]
description = "Fast Attention Algorithms for LLM Inference"
requires-python = ">=3.8"
readme = "README.md"
license = "Apache-2.0"
authors = [
    {name = "FlashInfer Team"}
]
dependencies = [
    "numpy",
    "torch>=2.0",
]

[tool.setuptools_scm]
write_to = "flashinfer/_version.py"
version_scheme = "post-release"
local_scheme = "no-local-version"
fallback_version = "0.0.0"

[tool.scikit-build]
cmake.version = "3.26.1"
cmake.args = ["-GNinja"]
build.verbose = true
logging.level = "INFO"
build-dir = "_skbuild"

[tool.scikit-build.wheel]
py-api = "cp38"
packages = ["flashinfer"]
install-dir = "."

[tool.scikit-build.cmake.define]
FLASHINFER_AOT_TORCH_EXTS_CUDA = "OFF"
FLASHINFER_ENABLE_F16 = "ON"
FLASHINFER_ENABLE_BF16 = "ON"
FLASHINFER_ENABLE_FP8_E4M3 = "OFF"
FLASHINFER_ENABLE_FP8_E5M2 = "OFF"
FLASHINFER_CUTLASS_DIR = "${CMAKE_CURRENT_SOURCE_DIR}/3rdparty/cutlass"

[tool.cibuildwheel]
build = "cp38-*"
build-frontend = "pip"
config-settings = {--build-option="--py-limited-api=cp38"}
